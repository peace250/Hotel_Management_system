    $sql_select = "SELECT * FROM hotel_rooms";
    $sql_run = mysqli_query($conn, $sql_select);

    if (mysqli_num_rows($sql_run) > 0) {
        echo "
            <thead>
              <th>No</th>
              <th>Image</th>
              <th>Name</th>
              <th>Description</th>
              <th>Price</th>
              <th>amenities</th>
              <th>capacity</th>
              <th>Type</th>
              <th>Status</th>
              <th>Operations</th>
      </thead> 
          ";
        $index = 0;
        while ($row = mysqli_fetch_assoc($sql_run)) {
            $index++;
            echo "<tbody>";
            echo "<tr>";
            echo  "<td> <b>" . $index . "</b></td>";
            echo "<td><img src='../" . htmlspecialchars($row['image']) . "' alt='Property Image' style='width: 120px; height: auto;'></td>";
            echo  "<td> <b>" . $row['name'] . "</b></td>";
            echo "<td class=''>" . $row['description'] . "</td>";
            echo "<td class=''>" . $row['price'] . "</td>";
            $amenities = json_decode($row['amenities'], true);
           echo "<td class=''>" . implode(", ", $amenities) . "</td>";
            echo "<td class=''>" . $row['capacity'] . "</td>";
            echo "<td class=''>" . $row['type'] . "</td>";
            echo "<td class=''>" . ucfirst($row['status']) . "</td>";

            echo '<td class="d-flex flex-row p-4">
